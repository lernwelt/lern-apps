<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>✏️ Sarah lernt Deutsch</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@700;800;900&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #1a0a2e;
  --card: #251545;
  --card2: #2d1a52;
  --border: #3d2570;
  --accent: #c084fc;
  --accent2: #f472b6;
  --accent3: #34d399;
  --orange: #fb923c;
  --red: #f87171;
  --text: #f3e8ff;
  --muted: #9d7ec9;
  --r: 14px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Nunito', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

.header {
  background: linear-gradient(135deg, #7c3aed 0%, #db2777 100%);
  padding: 20px 20px 0 20px;
  text-align: center;
}
.header h1 { font-family: 'Baloo 2', sans-serif; font-size: 1.6rem; font-weight: 900; color: white; margin-bottom: 4px; }
.header p { font-size: .85rem; color: rgba(255,255,255,.8); margin-bottom: 16px; }

.tabs { display: flex; gap: 4px; justify-content: center; padding: 0 10px; flex-wrap: wrap; }
.tab {
  padding: 10px 16px; border-radius: 10px 10px 0 0; border: none;
  font-family: 'Nunito', sans-serif; font-weight: 800; font-size: .82rem;
  cursor: pointer; color: rgba(255,255,255,.7); background: rgba(255,255,255,.1); transition: all .2s;
}
.tab.active { background: var(--bg); color: var(--accent); }

.content { padding: 20px 16px; max-width: 680px; margin: 0 auto; }
.section { display: none; }
.section.active { display: block; }

.card { background: var(--card); border: 1px solid var(--border); border-radius: var(--r); padding: 16px 18px; margin-bottom: 14px; }

/* COLLAPSIBLE */
.collapsible-header {
  display: flex; align-items: center; justify-content: space-between;
  cursor: pointer; user-select: none; padding: 14px 18px;
  background: var(--card); border: 1px solid var(--border);
  border-radius: var(--r); margin-bottom: 6px; transition: background .18s;
}
.collapsible-header:hover { background: var(--card2); }
.collapsible-header.open { border-radius: var(--r) var(--r) 0 0; border-bottom: none; margin-bottom: 0; }
.collapsible-title { font-family: 'Baloo 2', sans-serif; font-size: 1rem; font-weight: 800; color: var(--accent); display: flex; align-items: center; gap: 8px; }
.collapsible-arrow { color: var(--muted); font-size: .9rem; transition: transform .3s; }
.collapsible-header.open .collapsible-arrow { transform: rotate(180deg); }
.collapsible-body {
  background: var(--card); border: 1px solid var(--border); border-top: none;
  border-radius: 0 0 var(--r) var(--r); padding: 0 18px;
  max-height: 0; overflow: hidden; transition: max-height .35s ease, padding .35s ease; margin-bottom: 10px;
}
.collapsible-body.open { max-height: 3000px; padding: 14px 18px 18px 18px; }

/* REGEL-BOXEN */
.rule-box {
  background: var(--card2); border-radius: 10px; padding: 12px 14px;
  margin-bottom: 10px; border-left: 3px solid var(--accent); font-size: .9rem; line-height: 1.6;
}
.rule-box.green { border-left-color: var(--accent3); }
.rule-box.pink { border-left-color: var(--accent2); }
.rule-box.orange { border-left-color: var(--orange); }
.rule-box.red { border-left-color: var(--red); }

.example-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 10px 0;
}
.ex-item {
  background: var(--card2); border-radius: 8px; padding: 8px 12px; font-size: .88rem;
}
.ex-item .correct { color: var(--accent3); font-weight: 800; }
.ex-item .wrong { color: var(--red); text-decoration: line-through; font-weight: 600; }

.verb-table { width: 100%; border-collapse: collapse; font-size: .88rem; }
.verb-table th { text-align: left; color: var(--muted); font-size: .72rem; text-transform: uppercase; letter-spacing: 1px; padding: 6px 8px; border-bottom: 1px solid var(--border); }
.verb-table td { padding: 7px 8px; border-bottom: 1px solid var(--border); }
.verb-table tr:last-child td { border-bottom: none; }
.verb-table .inf { color: var(--accent); font-weight: 700; }
.verb-table .prt { color: var(--accent2); font-weight: 700; }
.verb-table .prf { color: var(--accent3); font-weight: 700; }

/* FEHLER-FALLEN */
.fallen-grid { display: flex; flex-direction: column; gap: 8px; margin: 10px 0; }
.fallen-item {
  background: var(--card2); border-radius: 8px; padding: 10px 14px;
  display: flex; align-items: center; justify-content: space-between; gap: 10px;
}
.fallen-wrong { color: var(--red); font-weight: 800; font-size: 1rem; text-decoration: line-through; }
.fallen-arrow { color: var(--muted); }
.fallen-right { color: var(--accent3); font-weight: 800; font-size: 1rem; }
.fallen-rule { font-size: .78rem; color: var(--muted); flex: 1; text-align: right; }

/* GAP / TEST shared */
.test-progress-bar { background: var(--border); border-radius: 10px; height: 6px; margin-bottom: 6px; }
.test-progress-fill { background: linear-gradient(90deg, var(--accent), var(--accent2)); height: 6px; border-radius: 10px; transition: width .4s; }
.test-counter { font-size: .78rem; color: var(--muted); text-align: right; margin-bottom: 16px; }
.test-question { font-size: 1.05rem; font-weight: 700; color: var(--text); margin-bottom: 14px; line-height: 1.5; }
.test-options { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }
.test-opt {
  padding: 11px 16px; border-radius: 10px; border: 1.5px solid var(--border);
  background: var(--card2); color: var(--text); font-family: 'Nunito', sans-serif;
  font-weight: 600; font-size: .93rem; cursor: pointer; text-align: left; transition: all .18s;
}
.test-opt:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
.test-opt.correct { border-color: var(--accent3); background: rgba(52,211,153,.1); color: var(--accent3); }
.test-opt.wrong { border-color: var(--red); background: rgba(248,113,113,.1); color: var(--red); }
.test-opt:disabled { cursor: default; }
.test-feedback { border-radius: 10px; padding: 10px 14px; font-weight: 700; font-size: .88rem; margin-bottom: 12px; display: none; }
.test-feedback.show { display: block; }
.test-feedback.good { background: rgba(52,211,153,.1); color: var(--accent3); border: 1px solid var(--accent3); }
.test-feedback.bad { background: rgba(248,113,113,.1); color: var(--red); border: 1px solid var(--red); }

/* GAP INPUT */
.gap-input {
  background: var(--card2); border: 2px solid var(--border); border-radius: 8px;
  color: var(--text); font-family: 'Nunito', sans-serif; font-weight: 700;
  font-size: .95rem; padding: 6px 12px; width: 160px; text-align: center; outline: none; transition: border-color .2s;
}
.gap-input:focus { border-color: var(--accent); }
.gap-input.correct { border-color: var(--accent3); background: rgba(52,211,153,.1); color: var(--accent3); }
.gap-input.wrong { border-color: var(--red); background: rgba(248,113,113,.1); color: var(--red); }

/* BUTTONS */
.btn { padding: 11px 24px; border-radius: 30px; border: none; font-family: 'Nunito', sans-serif; font-weight: 800; font-size: .95rem; cursor: pointer; transition: all .2s; }
.btn-primary { background: var(--accent); color: #1a0a2e; }
.btn-primary:hover { background: #d8b4fe; }
.btn-secondary { background: var(--card2); color: var(--text); border: 1px solid var(--border); }
.btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
.btn-green { background: var(--accent3); color: #1a0a2e; }

/* FLASHCARD */
.flashcard-container { perspective: 1000px; margin-bottom: 16px; }
.flashcard { width: 100%; min-height: 160px; position: relative; transform-style: preserve-3d; transition: transform .5s; cursor: pointer; }
.flashcard.flipped { transform: rotateY(180deg); }
.fc-front, .fc-back {
  position: absolute; width: 100%; min-height: 160px; backface-visibility: hidden;
  border-radius: var(--r); display: flex; flex-direction: column;
  align-items: center; justify-content: center; padding: 24px 20px; text-align: center;
}
.fc-front { background: linear-gradient(135deg, #251545, #2d1a52); border: 1px solid var(--border); }
.fc-back { background: linear-gradient(135deg, #1a0a2e, #251545); border: 1px solid var(--accent); transform: rotateY(180deg); }
.fc-label { font-size: .72rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
.fc-word { font-family: 'Baloo 2', sans-serif; font-size: 1.5rem; font-weight: 800; color: var(--text); line-height: 1.3; }
.fc-back .fc-word { color: var(--accent3); }
.fc-tap { font-size: .75rem; color: var(--muted); margin-top: 8px; }
.fc-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
.fc-counter { color: var(--muted); font-size: .85rem; font-weight: 700; }
.fc-progress { display: flex; gap: 4px; margin-bottom: 16px; flex-wrap: wrap; }
.fc-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); transition: background .3s; }
.fc-dot.seen { background: var(--accent2); }
.fc-dot.known { background: var(--accent3); }

.sel-btn {
  padding: 7px 14px; border-radius: 20px; border: 1.5px solid var(--border);
  background: var(--card2); color: var(--muted); font-family: 'Nunito', sans-serif;
  font-weight: 700; font-size: .8rem; cursor: pointer; transition: all .18s;
}
.sel-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(192,132,252,.08); }
.select-row { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }

.result-screen { text-align: center; padding: 20px 0; }
.result-emoji { font-size: 3rem; margin-bottom: 8px; }
.result-title { font-family: 'Baloo 2', sans-serif; font-size: 1.4rem; font-weight: 900; color: var(--accent); margin-bottom: 6px; }
.result-score { font-size: 2.2rem; font-weight: 900; color: var(--accent3); margin-bottom: 16px; }
.result-breakdown { background: var(--card2); border-radius: 12px; padding: 14px; text-align: left; margin-bottom: 16px; }
.rb-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--border); font-size: .88rem; }
.rb-row:last-child { border-bottom: none; }

.mod-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: .72rem; font-weight: 800; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 12px; }
.badge-rs { background: var(--accent); color: #1a0a2e; }
.badge-verb { background: var(--accent2); color: #1a0a2e; }
.badge-wort { background: var(--accent3); color: #1a0a2e; }
</style>
</head>
<body>

<div class="header">
  <h1>✏️ Sarah lernt Deutsch</h1>
  <p>Rechtschreibung · Grammatik · Starke Verben</p>
  <div class="tabs">
    <button class="tab active" onclick="showTab('zusammenfassung',this)">📖 Zusammenfassung</button>
    <button class="tab" onclick="showTab('lueckentext',this)">✏️ Lückentext</button>
    <button class="tab" onclick="showTab('karteikarten',this)">🃏 Karteikarten</button>
    <button class="tab" onclick="showTab('test',this)">🎯 Test</button>
  </div>
</div>

<div class="content">

<!-- ══════════════════════════════
     ZUSAMMENFASSUNG
══════════════════════════════ -->
<div class="section active" id="sec-zusammenfassung">

  <!-- SARAHS FEHLER-FALLEN -->
  <div class="collapsible-header open" onclick="toggleBlock(this)">
    <span class="collapsible-title">⚠️ Sarahs Fehler-Fallen</span>
    <span class="collapsible-arrow">▼</span>
  </div>
  <div class="collapsible-body open">
    <div class="fallen-grid">
      <div class="fallen-item">
        <span class="fallen-wrong">kamm</span>
        <span class="fallen-arrow">→</span>
        <span class="fallen-right">kam</span>
        <span class="fallen-rule">Präteritum von kommen</span>
      </div>
      <div class="fallen-item">
        <span class="fallen-wrong">lessen</span>
        <span class="fallen-arrow">→</span>
        <span class="fallen-right">lesen</span>
        <span class="fallen-rule">kein Doppel-s nach langem Vokal</span>
      </div>
      <div class="fallen-item">
        <span class="fallen-wrong">den</span>
        <span class="fallen-arrow">→</span>
        <span class="fallen-right">denn</span>
        <span class="fallen-rule">„denn" = weil (Konjunktion)</span>
      </div>
      <div class="fallen-item">
        <span class="fallen-wrong">das</span>
        <span class="fallen-arrow">→</span>
        <span class="fallen-right">dass</span>
        <span class="fallen-rule">„dass" = Konjunktion (weil...)</span>
      </div>
    </div>
    <div class="rule-box red">
      💡 <strong>Trick für dass/das:</strong> Ersetze es durch „weil" – geht es? → <strong style="color:var(--accent3)">dass</strong>. Geht es nicht? → <strong style="color:var(--accent2)">das</strong>
    </div>
    <div class="rule-box pink">
      💡 <strong>Trick für denn/den:</strong> Ersetze durch „weil" – geht es? → <strong style="color:var(--accent3)">denn</strong>. Ist es ein Artikel? → <strong style="color:var(--accent2)">den</strong>
    </div>
  </div>

  <!-- S/SS/ß -->
  <div class="collapsible-header" onclick="toggleBlock(this)">
    <span class="collapsible-title">📏 s / ss / ß – Regel</span>
    <span class="collapsible-arrow">▼</span>
  </div>
  <div class="collapsible-body">
    <div class="rule-box green">
      ✅ <strong>ss</strong> nach <em>kurzem</em> Vokal: er <strong>muss</strong>, das <strong>Wasser</strong>, ich <strong>esse</strong>
    </div>
    <div class="rule-box">
      ✅ <strong>ß</strong> nach <em>langem</em> Vokal oder Diphthong: er <strong>heißt</strong>, die <strong>Straße</strong>, wir <strong>ließen</strong>
    </div>
    <div class="rule-box orange">
      ✅ <strong>s</strong> am Wortende oder vor Konsonant: der <strong>Bus</strong>, das <strong>Haus</strong>
    </div>
    <div class="example-grid">
      <div class="ex-item"><span class="correct">er muss</span> (kurzes u)</div>
      <div class="ex-item"><span class="correct">er heißt</span> (langes ei)</div>
      <div class="ex-item"><span class="correct">das Wasser</span> (kurzes a)</div>
      <div class="ex-item"><span class="correct">die Straße</span> (langes a)</div>
      <div class="ex-item"><span class="wrong">er heisst</span></div>
      <div class="ex-item"><span class="wrong">das Wasser</span> ✓ aber <span class="wrong">Strase</span> ✗</div>
    </div>
  </div>

  <!-- DOPPELKONSONANTEN -->
  <div class="collapsible-header" onclick="toggleBlock(this)">
    <span class="collapsible-title">🔤 Doppelkonsonanten</span>
    <span class="collapsible-arrow">▼</span>
  </div>
  <div class="collapsible-body">
    <div class="rule-box">
      Nach einem <strong>kurzen Vokal</strong> wird der folgende Konsonant verdoppelt.
    </div>
    <div class="rule-box green">
      ✅ kurzer Vokal → Doppelkonsonant: <strong>Mutter</strong>, <strong>Sonne</strong>, <strong>rennen</strong>, <strong>kommen</strong>
    </div>
    <div class="rule-box orange">
      ✅ langer Vokal → KEIN Doppelkonsonant: <strong>lesen</strong>, <strong>schreiben</strong>, <strong>hören</strong>
    </div>
    <div class="example-grid">
      <div class="ex-item"><span class="correct">rennen</span> (kurzes e)</div>
      <div class="ex-item"><span class="correct">lesen</span> (langes e)</div>
      <div class="ex-item"><span class="correct">kommen</span> (kurzes o)</div>
      <div class="ex-item"><span class="correct">wohnen</span> (langes o)</div>
      <div class="ex-item"><span class="wrong">lessen</span> ✗</div>
      <div class="ex-item"><span class="wrong">rennen</span> ✓</div>
    </div>
  </div>

  <!-- DEHNUNGS-H -->
  <div class="collapsible-header" onclick="toggleBlock(this)">
    <span class="collapsible-title">🔇 Dehnungs-h</span>
    <span class="collapsible-arrow">▼</span>
  </div>
  <div class="collapsible-body">
    <div class="rule-box">
      Das Dehnungs-h zeigt einen <strong>langen Vokal</strong> an – es wird NICHT gesprochen.
    </div>
    <div class="rule-box green">
      ✅ Beispiele: <strong>fahren</strong>, <strong>Schuh</strong>, <strong>stehlen</strong>, <strong>Stuhl</strong>, <strong>wohnen</strong>, <strong>nehmen</strong>, <strong>Zahl</strong>
    </div>
    <div class="rule-box orange">
      ⚠️ Das Dehnungs-h steht NACH dem Vokal, nie davor!
    </div>
  </div>

  <!-- B/P D/T G/K -->
  <div class="collapsible-header" onclick="toggleBlock(this)">
    <span class="collapsible-title">🔚 b/p · d/t · g/k am Wortende</span>
    <span class="collapsible-arrow">▼</span>
  </div>
  <div class="collapsible-body">
    <div class="rule-box">
      Am Wortende klingen b→p, d→t, g→k. Zum Schreiben: <strong>verlängertes Wort</strong> bilden!
    </div>
    <div class="example-grid">
      <div class="ex-item">der <strong>Hund</strong> → die Hun<strong>d</strong>e ✅</div>
      <div class="ex-item">der <strong>Berg</strong> → die Ber<strong>g</strong>e ✅</div>
      <div class="ex-item">das <strong>Grab</strong> → die Grä<strong>b</strong>er ✅</div>
      <div class="ex-item">der <strong>Zug</strong> → die Zü<strong>g</strong>e ✅</div>
      <div class="ex-item"><span class="wrong">Hund → Hunt</span> ✗</div>
      <div class="ex-item"><span class="wrong">Berg → Berk</span> ✗</div>
    </div>
    <div class="rule-box green">
      💡 <strong>Trick:</strong> Bilde den Plural oder eine Ableitung – der richtige Buchstabe wird dann hörbar!
    </div>
  </div>

  <!-- DASS/DAS & DENN/DEN -->
  <div class="collapsible-header" onclick="toggleBlock(this)">
    <span class="collapsible-title">⚖️ dass / das · denn / den</span>
    <span class="collapsible-arrow">▼</span>
  </div>
  <div class="collapsible-body">
    <div class="rule-box green">
      <strong style="color:var(--accent3)">dass</strong> = Konjunktion (= „weil"-Test möglich)<br>
      Ich weiß, <strong>dass</strong> er kommt. → Ich weiß, weil er kommt. ✅
    </div>
    <div class="rule-box pink">
      <strong style="color:var(--accent2)">das</strong> = Artikel oder Pronomen<br>
      <strong>Das</strong> Kind spielt. / Ich sehe <strong>das</strong> Auto.
    </div>
    <div class="rule-box green" style="margin-top:10px">
      <strong style="color:var(--accent3)">denn</strong> = Konjunktion (= begründend, „weil"-Test)<br>
      Er bleibt, <strong>denn</strong> er ist müde. → Er bleibt, weil er müde ist. ✅
    </div>
    <div class="rule-box pink">
      <strong style="color:var(--accent2)">den</strong> = Artikel (Akkusativ maskulin)<br>
      Ich sehe <strong>den</strong> Mann.
    </div>
  </div>

  <!-- STARKE VERBEN -->
  <div class="collapsible-header" onclick="toggleBlock(this)">
    <span class="collapsible-title">💪 Starke Verben – Präteritum</span>
    <span class="collapsible-arrow">▼</span>
  </div>
  <div class="collapsible-body">
    <div class="rule-box">
      Starke Verben ändern im Präteritum ihren Stammvokal – kein -te!
    </div>
    <table class="verb-table">
      <tr><th>Infinitiv</th><th>Präteritum</th><th>Perfekt</th></tr>
      <tr><td class="inf">kommen</td><td class="prt">kam</td><td class="prf">ist gekommen</td></tr>
      <tr><td class="inf">gehen</td><td class="prt">ging</td><td class="prf">ist gegangen</td></tr>
      <tr><td class="inf">sehen</td><td class="prt">sah</td><td class="prf">hat gesehen</td></tr>
      <tr><td class="inf">lesen</td><td class="prt">las</td><td class="prf">hat gelesen</td></tr>
      <tr><td class="inf">schreiben</td><td class="prt">schrieb</td><td class="prf">hat geschrieben</td></tr>
      <tr><td class="inf">fahren</td><td class="prt">fuhr</td><td class="prf">ist gefahren</td></tr>
      <tr><td class="inf">laufen</td><td class="prt">lief</td><td class="prf">ist gelaufen</td></tr>
      <tr><td class="inf">nehmen</td><td class="prt">nahm</td><td class="prf">hat genommen</td></tr>
      <tr><td class="inf">geben</td><td class="prt">gab</td><td class="prf">hat gegeben</td></tr>
      <tr><td class="inf">finden</td><td class="prt">fand</td><td class="prf">hat gefunden</td></tr>
      <tr><td class="inf">bleiben</td><td class="prt">blieb</td><td class="prf">ist geblieben</td></tr>
      <tr><td class="inf">stehen</td><td class="prt">stand</td><td class="prf">hat gestanden</td></tr>
      <tr><td class="inf">rufen</td><td class="prt">rief</td><td class="prf">hat gerufen</td></tr>
      <tr><td class="inf">essen</td><td class="prt">aß</td><td class="prf">hat gegessen</td></tr>
      <tr><td class="inf">tragen</td><td class="prt">trug</td><td class="prf">hat getragen</td></tr>
    </table>
  </div>

</div>

<!-- ══════════════════════════════
     LÜCKENTEXT
══════════════════════════════ -->
<div class="section" id="sec-lueckentext">
  <div class="card">
    <div class="select-row">
      <button class="sel-btn active" id="sel-rs" onclick="selectGapTopic('rs',this)">📏 s/ss/ß & Doppelkons.</button>
      <button class="sel-btn" id="sel-wort" onclick="selectGapTopic('wort',this)">⚖️ dass/das · denn/den</button>
