let fcTopic = 'verben';
let fcCards = [];
let fcIdx = 0;
let fcKnown = new Set();
let fcSeen = new Set();

function selectFlashTopic(t, btn) {
  fcTopic = t;
  document.querySelectorAll('.sel-btn[id^="fsel-"]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  loadFlashCards();
}

function loadFlashCards() {
  if (fcTopic === 'verben') fcCards = FC_VERBEN;
  else if (fcTopic === 'fallen') fcCards = FC_FALLEN;
  else fcCards = FC_REGELN;
  fcIdx = 0; fcKnown = new Set(); fcSeen = new Set();
  document.getElementById('flashcard').classList.remove('flipped');

  const labels = {verben:['Infinitiv','Präteritum · Perfekt'], fallen:['Frage','Antwort'], regeln:['Frage','Antwort']};
  const [fl, bl] = labels[fcTopic];
  document.getElementById('fc-front-label').textContent = fl;
  document.getElementById('fc-back-label').textContent = bl;

  updateFlashCard();
  buildDots();
}

function updateFlashCard() {
  const c = fcCards[fcIdx];
  document.getElementById('fc-front-word').textContent = c.front;
  document.getElementById('fc-back-word').textContent = c.back;
  document.getElementById('fc-counter').textContent = `${fcIdx + 1} / ${fcCards.length}`;
  document.getElementById('flashcard').classList.remove('flipped');
  fcSeen.add(fcIdx);
  updateDots();
}

function flipCard() { document.getElementById('flashcard').classList.toggle('flipped'); }
function fcNext() { if (fcIdx < fcCards.length - 1) { fcIdx++; updateFlashCard(); } }
function fcPrev() { if (fcIdx > 0) { fcIdx--; updateFlashCard(); } }
function markCard(known) { if (known) fcKnown.add(fcIdx); else fcKnown.delete(fcIdx); updateDots(); fcNext(); }

function buildDots() {
  const c = document.getElementById('fc-dots'); c.innerHTML = '';
  fcCards.forEach((_, i) => { const d = document.createElement('div'); d.className = 'fc-dot'; d.id = `dot-${i}`; c.appendChild(d); });
}
function updateDots() {
  fcCards.forEach((_, i) => {
    const d = document.getElementById(`dot-${i}`); if (!d) return;
    if (fcKnown.has(i)) d.className = 'fc-dot known';
    else if (fcSeen.has(i)) d.className = 'fc-dot seen';
    else d.className = 'fc-dot';
  });
}

// ═══════════════════════════════════════════
// TEST
// ═══════════════════════════════════════════
let testTopic = 'all';
let testQueue = [];
let testIdx = 0;
let testAnswers = [];

function selectTestTopic(t, btn) {
  testTopic = t;
  document.querySelectorAll('.sel-btn[id^="tsel-"]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; }
  return a;
}

function startTest() {
  let pool = TEST_ALL;
  if (testTopic !== 'all') {
    const map = { rs:'s/ss/ß', wort:'dass/das', verb:'Starke Verben' };
    pool = pool.filter(q => q.cat === map[testTopic] || q.cat === 'Doppelkonsonanten' || q.cat === 'b/p d/t g/k');
    if (testTopic === 'rs') pool = TEST_ALL.filter(q => ['s/ss/ß','Doppelkonsonanten'].includes(q.cat));
    if (testTopic === 'wort') pool = TEST_ALL.filter(q => ['dass/das','denn/den'].includes(q.cat));
    if (testTopic === 'verb') pool = TEST_ALL.filter(q => q.cat === 'Starke Verben');
  }
  testQueue = shuffle(pool).slice(0, 20);
  testIdx = 0; testAnswers = [];
  document.getElementById('test-start').style.display = 'none';
  document.getElementById('test-result').style.display = 'none';
  document.getElementById('test-running').style.display = 'block';
  showTestQuestion();
}

function showTestQuestion() {
  const q = testQueue[testIdx];
  document.getElementById('test-pbar').style.width = (testIdx / testQueue.length * 100) + '%';
  document.getElementById('test-counter').textContent = `Frage ${testIdx + 1} von ${testQueue.length}`;
  document.getElementById('test-q').textContent = q.q;
  const optsEl = document.getElementById('test-opts');
  optsEl.innerHTML = '';
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'test-opt'; btn.textContent = opt;
    btn.onclick = () => selectTestAnswer(i);
    optsEl.appendChild(btn);
  });
  document.getElementById('test-fb').className = 'test-feedback';
  document.getElementById('test-next').style.display = 'none';
}

function selectTestAnswer(i) {
  if (document.getElementById('test-next').style.display === 'block') return;
  const q = testQueue[testIdx];
  setTimeout(() => {
    const btns = document.querySelectorAll('.test-opt');
    btns.forEach(b => b.disabled = true);
    const correct = i === q.a;
    testAnswers.push({ q, chosen: i, correct });
    btns[q.a].className = 'test-opt correct';
    if (!correct) btns[i].className = 'test-opt wrong';
    const fb = document.getElementById('test-fb');
    fb.className = `test-feedback show ${correct ? 'good' : 'bad'}`;
    fb.textContent = correct ? '✅ Richtig!' : `❌ Richtig wäre: "${q.opts[q.a]}" · ${q.e}`;
    document.getElementById('test-next').style.display = 'block';
  }, 300);
}

function testNext() {
  testIdx++;
  if (testIdx >= testQueue.length) showTestResult();
  else showTestQuestion();
}

function showTestResult() {
  document.getElementById('test-running').style.display = 'none';
  document.getElementById('test-result').style.display = 'block';
  const correct = testAnswers.filter(a => a.correct).length;
  const total = testAnswers.length;
  const pct = Math.round(correct / total * 100);
  document.getElementById('res-emoji').textContent = pct >= 85 ? '🏆' : pct >= 70 ? '⭐' : pct >= 50 ? '💪' : '📖';
  document.getElementById('res-score').textContent = `${correct} / ${total} (${pct}%)`;
  const cats = {};
  testAnswers.forEach(a => {
    if (!cats[a.q.cat]) cats[a.q.cat] = { c: 0, t: 0 };
    cats[a.q.cat].t++;
    if (a.correct) cats[a.q.cat].c++;
  });
  let html = '';
  Object.entries(cats).forEach(([cat, v]) => {
    html += `<div class="rb-row"><span>${cat}</span><span style="color:var(--accent3)">${v.c}/${v.t}</span></div>`;
  });
  document.getElementById('res-breakdown').innerHTML = html;
}

