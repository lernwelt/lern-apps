// TABS & COLLAPSIBLE
// ═══════════════════════════════════════════
function showTab(name, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('sec-' + name).classList.add('active');
  if (btn) btn.classList.add('active');
  else {
    const tabs = {zusammenfassung:0,lueckentext:1,karteikarten:2,test:3};
    document.querySelectorAll('.tab')[tabs[name]]?.classList.add('active');
  }
}

function toggleBlock(header) {
  const body = header.nextElementSibling;
  const isOpen = header.classList.contains('open');
  header.classList.toggle('open', !isOpen);
  body.classList.toggle('open', !isOpen);
}

// ═══════════════════════════════════════════
// LÜCKENTEXT
// ═══════════════════════════════════════════
let gapTopic = 'rs';
let gapQueue = [];
let gapIdx = 0;
let gapCorrect = 0;

function selectGapTopic(t, btn) {
  gapTopic = t;
  document.querySelectorAll('.sel-btn[id^="sel-"]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  startGaps();
}

function startGaps() {
  const data = gapTopic === 'rs' ? GAP_RS : gapTopic === 'wort' ? GAP_WORT : GAP_VERB;
  gapQueue = shuffle([...data]);
  gapIdx = 0; gapCorrect = 0;
  document.getElementById('gap-result').style.display = 'none';
  document.getElementById('gap-single').style.display = 'block';

  const badges = {rs:['s / ss / ß · Doppelkonsonanten','badge-rs'], wort:['dass / das · denn / den','badge-wort'], verb:['Starke Verben Präteritum','badge-verb']};
  const [label, cls] = badges[gapTopic];
  document.getElementById('gap-badge').textContent = label;
  document.getElementById('gap-badge').className = 'mod-badge ' + cls;
  document.getElementById('gap-instruction').textContent = 'Trage das richtige Wort in die Lücke ein.';
  showGapQuestion();
}

function showGapQuestion() {
  const item = gapQueue[gapIdx];
  const total = gapQueue.length;
  document.getElementById('gap-pbar').style.width = (gapIdx / total * 100) + '%';
  document.getElementById('gap-counter').textContent = `Satz ${gapIdx + 1} von ${total}`;
  const sentence = item.s.replace('___', '<span style="color:var(--accent);font-weight:800">___</span>');
  document.getElementById('gap-display').innerHTML =
    `<div style="font-size:.82rem;color:var(--muted);margin-bottom:8px">📌 Stammwort: <strong style="color:var(--accent2)">${item.stammwort}</strong></div>${sentence}`;
  const inp = document.getElementById('gap-answer');
  inp.value = ''; inp.disabled = false; inp.className = 'gap-input';
  inp.style.width = gapTopic === 'verb' && item.a.includes(',') ? '200px' : '160px';
  document.getElementById('gap-fb').className = 'test-feedback';
  document.getElementById('gap-check-btn').style.display = 'inline-block';
  document.getElementById('gap-next-btn').style.display = 'none';
  setTimeout(() => inp.focus(), 100);
}

function checkSingleGap() {
  const item = gapQueue[gapIdx];
  const inp = document.getElementById('gap-answer');
  const val = inp.value.trim().toLowerCase();
  const expected = item.a.toLowerCase();
  const correct = val === expected;
  inp.disabled = true;
  inp.className = 'gap-input ' + (correct ? 'correct' : 'wrong');
  const fb = document.getElementById('gap-fb');
  if (correct) {
    gapCorrect++;
    fb.className = 'test-feedback show good';
    fb.textContent = '✅ Richtig!';
  } else {
    fb.className = 'test-feedback show bad';
    fb.innerHTML = `❌ Richtig wäre: <strong style="color:var(--accent3)">${item.a}</strong> · ${item.hint}`;
  }
  document.getElementById('gap-check-btn').style.display = 'none';
  document.getElementById('gap-next-btn').style.display = 'inline-block';
}

function nextSingleGap() {
  gapIdx++;
  if (gapIdx >= gapQueue.length) showGapResult();
  else showGapQuestion();
}

function showGapResult() {
  document.getElementById('gap-single').style.display = 'none';
  document.getElementById('gap-result').style.display = 'block';
  const pct = Math.round(gapCorrect / gapQueue.length * 100);
  document.getElementById('gap-res-emoji').textContent = pct >= 85 ? '🏆' : pct >= 65 ? '⭐' : '💪';
  document.getElementById('gap-res-score').textContent = `${gapCorrect} / ${gapQueue.length} richtig (${pct}%)`;
  document.getElementById('gap-pbar').style.width = '100%';
  document.getElementById('gap-counter').textContent = 'Fertig!';
}

